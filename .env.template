# Copy this file to `.env` and fill values
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DB=YourSqlServerDb
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=YourStrong!Passw0rd

PG_HOST=localhost
PG_PORT=5432
PG_DB=your_target_db
PG_USER=postgres
PG_PASSWORD=postgres
PG_ADMIN_DB=postgres

# Optional: local Foundry model settings for AI enhancement step
FOUNDRY_ENDPOINT=
FOUNDRY_API_KEY=
FOUNDRY_MODEL=phi-4-mini

# true = drops/recreates tables in PostgreSQL during pgloader run
RECREATE_TARGET=true

# Optional object filters (comma-separated, no spaces). Leave empty to include all.
INCLUDE_SCHEMAS=
EXCLUDE_SCHEMAS=sys,INFORMATION_SCHEMA
